# Unity generierte Ordner (MÜSSEN ignoriert werden)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Speicher- und Aufnahme-Dumps (können gigantisch werden)
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Autogenerierte IDE- und Projektdateien (Visual Studio, Rider etc.)
.vs/
.gradle/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generierte Meta-Dateien für ignorierte Dateien
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash-Reports
sysinfo.txt
crashlytics-build.properties

# Gebaute Applikationen / Builds (sollten nicht ins Repo)
*.apk
*.aab
*.unitypackage
*.app

# Plugins (optional, bei Bedarf auskommentieren)
# /[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*
